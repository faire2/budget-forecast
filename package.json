{
  "name": "budget-forecast",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "yarn workspace budget-forecast-client dev",
    "build": "cd client && yarn build",
    "lint": "yarn workspaces run lint",
