    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "dependencies": {
    "drizzle-orm": "^0.30.0",
    "@neondatabase/serverless": "^0.9.0",
    "zod": "^3.22.0",
    "date-fns": "^3.3.0"
  },
  "devDependencies": {
    "@vercel/node": "^5.6.22",
    "concurrently": "^8.2.2",
    "prettier": "^3.2.5"
  }
}
